{
  "name": "elegant-code-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "web",
    "mobile"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=shared\" \"npm run dev --workspace=backend\" \"npm run dev --workspace=web\"",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspaces --if-present"
  },
  "dependencies": {
    "concurrently": "^10.0.3"
  }
}
